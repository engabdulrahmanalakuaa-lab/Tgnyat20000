{
  "name": "technologies-soft-pro",
  "version": "3.0.0",
  "description": "نظام إدارة المطاعم المتكامل - تقنيات سوفت Pro",
  "main": "main.js",
  "author": "تقنيات سوفت - م/ عبدالرحمن الاكوع",
  "license": "Proprietary",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --ia32 --x64",
    "dist:x64": "electron-builder --win --x64",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "bcryptjs": "^2.4.3",
    "node-thermal-printer": "^4.4.4",
    "pdfmake": "^0.2.10"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.technologies-soft.pos",
    "productName": "Technologies Soft Pro",
    "copyright": "Copyright © 2024 تقنيات سوفت",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bcryptjs/**/*",
      "node_modules/node-thermal-printer/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Technologies-Soft-Pro-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "تقنيات سوفت Pro",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": "Technologies Soft"
    },
    "files": [
      "**/*",
      "!dist",
      "!**/*.md",
      "!**/.git",
      "!**/.github",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["**/*"]
      },
      {
        "from": "vendor",
        "to": "vendor",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    }
  }
}
